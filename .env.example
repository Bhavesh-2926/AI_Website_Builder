# =========================================================================
# Backend Environment Configuration
# =========================================================================
# Port to run FastAPI server (default: 8000)
PORT=8000

# OpenAI API credentials (required for real AI copy and design systems)
OPENAI_API_KEY=your_openai_api_key_here

# Supabase database connectivity
# Required for persistent storage, user synchronizations, and RLS tables.
# Leave blank to run the server in developer sandbox "Offline Mock" mode.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# =========================================================================
# Frontend Environment Configuration
# =========================================================================
# Client-side Supabase credentials
# Leave blank to bypass Supabase auth and log in with the sandbox bypass demo button.
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
